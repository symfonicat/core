{% set prototype_markup %}
    {{ include('@symfonicat/middleware/_collection_item.html.twig', { item_form: form.vars.prototype }) }}
{% endset %}

<div class="mb-3">
    {{ form_label(form, null, {
        label_attr: {
            class: 'pt-0'
        }
    }) }}
    {{ form_errors(form) }}

    <div
        class="d-grid gap-2"
        data-controller="middleware-collection"
        data-middleware-collection-index-value="{{ form|length }}"
    >
        <div class="d-grid gap-2" data-middleware-collection-target="items">
            {% for item_form in form %}
                {{ include('@symfonicat/middleware/_collection_item.html.twig', { item_form: item_form }) }}
            {% endfor %}
        </div>

        <template data-middleware-collection-target="prototype">{{ prototype_markup|raw }}</template>

        <button type="button" class="btn btn-sm btn-outline-secondary align-self-start" data-action="middleware-collection#add">add middleware</button>
    </div>
</div>
