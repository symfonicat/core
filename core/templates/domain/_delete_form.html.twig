<form method="post" action="{{ path('symfonicat_domain_delete', {'id': domain.tld}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="d-inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ domain.tld) }}">
    <button class="btn btn-sm btn-danger">
        <i class="fa fa-times">&nbsp;</i>
    </button>
</form>
