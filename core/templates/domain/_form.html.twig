{{ form_start(form) }}

<div class="row g-3">
    <div class="col-md-6">

        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.id) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.parcel) }}
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.catch) }}
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-12">
                {{ form_row(form.modules) }}
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-12">
                {{ include('@symfonicat/middleware/_collection.html.twig', { form: form.middlewares }) }}
            </div>
        </div>

    </div>
    <div class="col-md-6">

        <div class="row g-3">
            <div class="col-md-12">
                {{ include('@symfonicat/env/_env_collection.html.twig', { form: form.env }) }}
            </div>
        </div>
        
    </div>
</div>

{% if form._token is defined %}
    {{ form_widget(form._token) }}
{% endif %}

<div class="d-flex justify-content-end">
    <button class="btn btn-sm btn-success">{{ button_label|default('save') }}</button>
</div>

{{ form_end(form, { render_rest: false }) }}
