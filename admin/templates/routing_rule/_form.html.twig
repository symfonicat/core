{% set argument_prototype %}
    <div data-routing-rule-form-argument-item>
        <div class="input-group input-group-sm">
            {{ form_widget(form.arguments.vars.prototype) }}
            <button
                type="button"
                class="btn btn-outline-danger"
                data-action="click->routing-rule-form#removeArgument"
            >remove</button>
        </div>
    </div>
{% endset %}

{{ form_start(form, {
    attr: {
        'data-controller': 'routing-rule-form'
    }
}) }}

<div class="card mb-3">
    <div class="card-header">rule</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.type, {
                    attr: {
                        'data-action': 'change->routing-rule-form#update',
                        'data-routing-rule-form-target': 'type'
                    }
                }) }}

                {{ form_row(form.applicationType, {
                    attr: {
                        'data-action': 'change->routing-rule-form#update',
                        'data-routing-rule-form-target': 'applicationType'
                    },
                    row_attr: {
                        'data-routing-rule-form-target': 'applicationTypeRow'
                    }
                }) }}

                {{ form_row(form.redirectType, {
                    attr: {
                        'data-action': 'change->routing-rule-form#update',
                        'data-routing-rule-form-target': 'redirectType'
                    },
                    row_attr: {
                        'data-routing-rule-form-target': 'redirectTypeRow'
                    }
                }) }}

                {{ form_row(form.routeType, {
                    attr: {
                        'data-action': 'change->routing-rule-form#update',
                        'data-routing-rule-form-target': 'routeType'
                    },
                    row_attr: {
                        'data-routing-rule-form-target': 'routeTypeRow'
                    }
                }) }}
            </div>

            <div class="col-md-6" data-routing-rule-form-target="argumentsRow">
                <div class="mb-3">
                    {{ form_label(form.arguments) }}
                    {{ form_errors(form.arguments) }}
                    {{ form_help(form.arguments) }}

                    <div
                        class="d-grid gap-2 mt-2"
                        data-routing-rule-form-target="argumentsCollection"
                        data-routing-rule-form-index="{{ form.arguments|length }}"
                    >
                        <div class="d-grid gap-2" data-routing-rule-form-target="argumentsItems">
                            {% for argument_form in form.arguments %}
                                <div data-routing-rule-form-argument-item>
                                    <div class="input-group input-group-sm">
                                        {{ form_widget(argument_form) }}
                                        <button
                                            type="button"
                                            class="btn btn-outline-danger"
                                            data-action="click->routing-rule-form#removeArgument"
                                        >remove</button>
                                    </div>
                                    {{ form_errors(argument_form) }}
                                </div>
                            {% endfor %}
                        </div>

                        <template data-routing-rule-form-target="argumentsPrototype">{{ argument_prototype|raw }}</template>

                        <button
                            type="button"
                            class="btn btn-sm btn-outline-secondary align-self-start"
                            data-action="click->routing-rule-form#addArgument"
                        >add argument</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">match</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6" data-routing-rule-form-target="domainRow">
                {{ form_row(form.domain) }}
            </div>

            <div class="col-md-12" data-routing-rule-form-target="projectRow">
                {{ form_row(form.project) }}
            </div>

            <div class="col-md-12" data-routing-rule-form-target="applicationRow">
                {{ form_row(form.application) }}
            </div>
        </div>
    </div>
</div>

<div class="card mb-3" data-routing-rule-form-target="redirectCard">
    <div class="card-header">redirect</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.redirectTarget, {
                    attr: {
                        'data-action': 'change->routing-rule-form#update',
                        'data-routing-rule-form-target': 'redirectTarget'
                    },
                    row_attr: {
                        'data-routing-rule-form-target': 'redirectTargetRow'
                    }
                }) }}
            </div>

            <div class="col-md-6">
                {{ form_row(form.redirectDomain, {
                    row_attr: {
                        'data-routing-rule-form-target': 'redirectDomainRow'
                    }
                }) }}
                {{ form_row(form.redirectProject, {
                    row_attr: {
                        'data-routing-rule-form-target': 'redirectProjectRow'
                    }
                }) }}
            </div>
        </div>
    </div>
</div>

<div class="card mb-3" data-routing-rule-form-target="routeCard">
    <div class="card-header">route</div>
    <div class="card-body">
        {{ form_row(form.route, {
            row_attr: {
                'data-routing-rule-form-target': 'routeRow'
            }
        }) }}
    </div>
</div>

<div class="d-flex justify-content-end">
    <button class="btn btn-sm btn-success">save</button>
</div>

{% if form._token is defined %}
    {{ form_widget(form._token) }}
{% endif %}

{{ form_end(form, { render_rest: false }) }}
