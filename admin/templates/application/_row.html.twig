<tr id="application_{{ application.id(false) }}" class="btn-row">
    <td class="fw-semibold">{{ application.name }}</td>
    <td>{{ application.type }}</td>
    <td><b>{% if application.domain %}{{ application.domain.id(false) }}{% else %}<i class="fa fa-fw fa-times"></i>{% endif %}</b></td>
    <td><b>{% if application.subdomain %}{{ application.subdomain.id }}{% else %}<i class="fa fa-fw fa-times"></i>{% endif %}</b></td>
    {% for env_parent in env_parents %}
        <td>
            {% set entries = env_parent_entries(application.env, env_parent) %}
            {% for entry in entries %}
                <div><code>{{ entry }}</code></div>
            {% else %}
                <i class="fa fa-fw fa-times"></i>
            {% endfor %}
        </td>
    {% endfor %}
    <td class="text-end btn-cell">
        <div class="btn-group btn-group-sm">
            <a href="{{ path('symfonicat_application_edit', { id: application.id }) }}" class="btn btn-sm btn-warning">
                <i class="fa fa-pencil">&nbsp;</i>
            </a>
            {{ include('@symfonicat/application/_delete_form.html.twig') }}
        </div>
    </td>
</tr>
