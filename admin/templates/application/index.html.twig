{% extends '@symfonicat/base.html.twig' %}
{% block title %}Application{% endblock %}
{% block body %}

    <div class="d-flex justify-content-end mb-1">
        <a href="{{ path('symfonicat_application_create') }}" class="btn btn-sm btn-success">create application</a>
    </div>

    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>name</th>
                <th>id</th>
                <th>type</th>
                <th>domain</th>
                <th>subdomain</th>
                <th>endpoint</th>
                {% for env_parent in env_parents %}
                    <th>{{ env_parent.id }}</th>
                {% endfor %}
                <th class="text-end">&nbsp;</th>
            </tr>
        </thead>
        <tbody>
        {% for application in applications %}
            {{ include('@symfonicat/application/_row.html.twig') }}
        {% else %}
            <tr>
                <td colspan="{{ 7 + env_parents|length }}">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
