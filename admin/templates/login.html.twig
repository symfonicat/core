{% extends '@symfonicat/base.html.twig' %}

{% block title %}Admin MFA{% endblock %}

{% block body %}
    {% if admin is same as(null) %}
        <div class="row justify-content-center py-4">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="card text-white border-secondary shadow">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-3">Admin Login</h1>
                        <p class="text-secondary mb-4">
                            Enter your admin email and password to continue to the TOTP step.
                        </p>

                        {% if error %}
                            <div class="alert alert-danger">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <form method="post" action="{{ path('symfonicat_admin_login_check') }}" class="d-grid gap-3">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('symfonicat_admin_login') }}">

                            <input
                                id="email"
                                name="email"
                                type="email"
                                autocomplete="username"
                                value="{{ last_username }}"
                                class="form-control form-control-lg"
                                required
                                autofocus
                            >

                            <input
                                id="password"
                                name="password"
                                type="password"
                                autocomplete="current-password"
                                class="form-control form-control-lg"
                                required
                            >

                            <button type="submit" class="btn btn-light">continue</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="row justify-content-center py-4">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="card text-white border-secondary shadow">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-3">Authentication Code</h1>
                        <p class="text-secondary mb-4">
                            Logged in as <strong>{{ admin.email }}</strong>.
                            Enter the current code from your TOTP app to continue.
                        </p>

                        <form method="post" action="{{ path('symfonicat_admin_login') }}" class="d-grid gap-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('symfonicat_admin_mfa') }}">

                            <input
                                id="mfa-code"
                                name="code"
                                type="text"
                                inputmode="numeric"
                                autocomplete="one-time-code"
                                pattern="[0-9 ]*"
                                maxlength="8"
                                class="form-control form-control-lg"
                                required
                                autofocus
                            >

                            <button type="submit" class="btn btn-light">verify</button>
                        </form>

                        <div class="mt-3">
                            <a href="{{ path('symfonicat_admin_logout') }}" class="btn btn-danger">log out</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
