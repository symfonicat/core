{% extends '@symfonicat/base.html.twig' %}
{% block title %}Subdomains{% endblock %}
{% block body %}

    <table class="table" id="subdomain">
        <thead>
            <tr>
                <th>name</th>
                <th>modules</th>
                {% for env_parent in env_parents %}
                    <th>{{ env_parent.id }}</th>
                {% endfor %}
                <th>&nbsp;</th>
            </tr>
        </thead>
        <tbody id="subdomain-body">
        {% for subdomain in subdomains %}
            {{ include('@symfonicat/subdomain/_row.html.twig') }}
        {% else %}
            <tr id="subdomain-empty">
                <td colspan="{{ 3 + env_parents|length }}">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    
{% endblock %}
