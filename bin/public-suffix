#!/usr/bin/env php
<?php

declare(strict_types=1);

$target = dirname(__DIR__).'/public_suffix_list.dat';
$url = 'https://publicsuffix.org/list/public_suffix_list.dat';

$context = stream_context_create([
    'http' => [
        'timeout' => 30,
        'user_agent' => 'symfonicat-core/0.1',
    ],
    'ssl' => [
        'verify_peer' => true,
        'verify_peer_name' => true,
    ],
]);

$content = @file_get_contents($url, false, $context);
if ($content === false || trim($content) === '') {
    fwrite(STDERR, sprintf("Failed to download %s\n", $url));

    exit(1);
}

if (@file_put_contents($target, $content) === false) {
    fwrite(STDERR, sprintf("Failed to write %s\n", $target));

    exit(1);
}

fwrite(STDOUT, sprintf("Updated %s\n", $target));
