#!/bin/sh

set -eu

load_env_file() {
    file="$1"

    [ -f "$file" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ''|\#*)
                continue
                ;;
            export\ *)
                line=${line#export }
                ;;
        esac

        case "$line" in
            *=*)
                key=${line%%=*}
                case "$key" in
                    ''|*[!A-Za-z0-9_]*)
                        continue
                        ;;
                esac

                eval "current=\${$key+x}"
                if [ -z "$current" ]; then
                    eval "export $line"
                fi
                ;;
        esac
    done < "$file"
}

require_var() {
    name="$1"

    eval "value=\${$name:-}"
    if [ -z "$value" ]; then
        printf >&2 'Missing required environment variable: %s\n' "$name"
        exit 1
    fi
}

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
project_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)

load_env_file "$project_dir/.env"
load_env_file "$project_dir/.env.local"
if [ -n "${APP_ENV:-}" ]; then
    load_env_file "$project_dir/.env.${APP_ENV}"
    load_env_file "$project_dir/.env.${APP_ENV}.local"
fi

require_var DOCKERHUB_USERNAME
require_var DOCKERHUB_TOKEN
require_var DOCKERHUB_REPOSITORY

context="${DOCKERHUB_CONTEXT:-$project_dir}"
dockerfile="${DOCKERHUB_DOCKERFILE:-Dockerfile}"
target="${DOCKERHUB_BUILD_TARGET:-runtime}"
local_image="${DOCKERHUB_LOCAL_IMAGE:-symfonicat-core-php:local}"
registry="${DOCKERHUB_REGISTRY:-docker.io}"
namespace="${DOCKERHUB_NAMESPACE:-$DOCKERHUB_USERNAME}"
tag="${DOCKERHUB_TAG:-latest}"
remote_image="${registry}/${namespace}/${DOCKERHUB_REPOSITORY}:${tag}"

docker build \
    --file "$dockerfile" \
    --target "$target" \
    --tag "$local_image" \
    "$context"

docker tag "$local_image" "$remote_image"

printf '%s' "$DOCKERHUB_TOKEN" | docker login "$registry" --username "$DOCKERHUB_USERNAME" --password-stdin
docker push "$remote_image"
