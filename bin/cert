#!/bin/sh

set -eu

load_env_file() {
    file="$1"

    [ -f "$file" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ''|\#*)
                continue
                ;;
            export\ *)
                line=${line#export }
                ;;
        esac

        case "$line" in
            *=*)
                key=${line%%=*}
                case "$key" in
                    ''|*[!A-Za-z0-9_]*)
                        continue
                        ;;
                esac

                eval "current=\${$key+x}"
                if [ -z "$current" ]; then
                    eval "export $line"
                fi
                ;;
        esac
    done < "$file"
}

require_var() {
    name="$1"

    eval "value=\${$name:-}"
    if [ -z "$value" ]; then
        printf >&2 'Missing required environment variable: %s\n' "$name"
        exit 1
    fi
}

require_aws_credentials() {
    if [ -n "${AWS_PROFILE:-}" ] || [ -n "${AWS_DEFAULT_PROFILE:-}" ]; then
        return 0
    fi

    if [ -n "${AWS_ACCESS_KEY_ID:-}" ] && [ -n "${AWS_SECRET_ACCESS_KEY:-}" ]; then
        return 0
    fi

    printf >&2 '%s\n' \
        'Missing AWS credentials for the cert helper.' \
        'Set AWS_PROFILE, or export AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY (plus AWS_SESSION_TOKEN if using temporary credentials).' \
        'The script only loads local dotenv files; it does not create AWS credentials.'
    exit 1
}

ensure_hosted_zone() {
    route53_region="$1"
    domain="$2"
    zone_name="$domain."

    zone_lookup_json=$(aws route53 list-hosted-zones-by-name \
        --region "$route53_region" \
        --dns-name "$zone_name" \
        --output json)

    zone_id=$(printf '%s\n' "$zone_lookup_json" | jq -r --arg zone "$zone_name" '.HostedZones[]? | select(.Name == $zone) | .Id' | head -n1)
    created_zone=0

    if [ -z "$zone_id" ] || [ "$zone_id" = "null" ]; then
        caller_reference=$(printf '%s-%s-%s' "$domain" "$$" "$(date -u +%s)")
        zone_json=$(aws route53 create-hosted-zone \
            --region "$route53_region" \
            --name "$zone_name" \
            --caller-reference "$caller_reference" \
            --hosted-zone-config "Comment=Managed by symfonicat cert helper,PrivateZone=false" \
            --output json)

        zone_id=$(printf '%s\n' "$zone_json" | jq -r '.HostedZone.Id')
        created_zone=1
    else
        zone_json=$(aws route53 get-hosted-zone \
            --region "$route53_region" \
            --id "$zone_id" \
            --output json)
    fi

    zone_name=$(printf '%s\n' "$zone_json" | jq -r '.HostedZone.Name')
    name_servers=$(printf '%s\n' "$zone_json" | jq -r '.DelegationSet.NameServers[]')

    printf '%s\n%s\n%s\n' "$zone_id" "$zone_name" "$created_zone"
    printf '%s\n' "$name_servers" | sed 's/^/NS /'
}

apply_validation_records() {
    region="$1"
    zone_id="$2"
    validation_records_json="$3"

    change_batch_json=$(mktemp)

    jq -n \
        --argjson records "$validation_records_json" '
            {
                Changes: (
                    $records
                    | unique_by(.name, .type, .value)
                    | map({
                        Action: "UPSERT",
                        ResourceRecordSet: {
                            Name: .name,
                            Type: .type,
                            TTL: 300,
                            ResourceRecords: [{Value: .value}]
                        }
                    })
                )
            }
        ' > "$change_batch_json"

    if ! aws route53 change-resource-record-sets \
        --region "$region" \
        --hosted-zone-id "$zone_id" \
        --change-batch "file://$change_batch_json" \
        --output json >/dev/null; then
        rm -f "$change_batch_json"
        exit 1
    fi
    rm -f "$change_batch_json"
}

wait_for_validation_records() {
    region="$1"
    certificate_arn="$2"

    attempt=0
    while [ "$attempt" -lt 60 ]; do
        validation_records_json=$(
            aws acm describe-certificate \
                --region "$region" \
                --certificate-arn "$certificate_arn" \
                --query 'Certificate.DomainValidationOptions[?ResourceRecord].{name:ResourceRecord.Name,type:ResourceRecord.Type,value:ResourceRecord.Value}' \
                --output json
        )

        if [ "$(printf '%s\n' "$validation_records_json" | jq 'length')" -gt 0 ]; then
            printf '%s\n' "$validation_records_json"
            return 0
        fi

        attempt=$((attempt + 1))
        sleep 5
    done

    printf >&2 'ACM did not expose DNS validation records for %s in time\n' "$certificate_arn"
    exit 1
}

wait_for_certificate_issued() {
    region="$1"
    certificate_arn="$2"

    attempt=0
    while [ "$attempt" -lt 120 ]; do
        status=$(
            aws acm describe-certificate \
                --region "$region" \
                --certificate-arn "$certificate_arn" \
                --query 'Certificate.Status' \
                --output text
        )

        if [ "$status" = "ISSUED" ]; then
            return 0
        fi

        if [ "$status" = "FAILED" ] || [ "$status" = "REVOKED" ] || [ "$status" = "EXPIRED" ] || [ "$status" = "VALIDATION_TIMED_OUT" ]; then
            printf >&2 'ACM certificate %s ended in status %s\n' "$certificate_arn" "$status"
            exit 1
        fi

        attempt=$((attempt + 1))
        sleep 5
    done

    printf >&2 'ACM certificate %s never became ISSUED\n' "$certificate_arn"
    exit 1
}

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
project_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)

if [ "$#" -ne 1 ]; then
    printf >&2 'Usage: %s <domain>\n' "$(basename "$0")"
    exit 1
fi

domain=${1%.}
zone_name="$domain."

load_env_file "$project_dir/.env"
load_env_file "$project_dir/.env.local"
load_env_file "$project_dir/.env.certificate.local"
if [ -n "${APP_ENV:-}" ]; then
    load_env_file "$project_dir/.env.${APP_ENV}"
    load_env_file "$project_dir/.env.${APP_ENV}.local"
fi

require_var AWS_ECS_REGION
require_var AWS_ECS_CLUSTER_NAME
require_var AWS_ECS_SERVICE_NAME
require_var AWS_ECS_CONTAINER_NAME
require_var AWS_ECS_IMAGE_URI
require_aws_credentials

cert_region="${AWS_CERT_REGION:-${AWS_ECS_REGION:-${AWS_ROUTE53_REGION:-us-east-1}}}"
route53_region="${AWS_ROUTE53_REGION:-$cert_region}"
env_file="$project_dir/.env.certificate.local"
cert_dir="$project_dir/var/certificates/$domain"
mkdir -p "$cert_dir"

zone_info=$(
    ensure_hosted_zone "$route53_region" "$domain"
)
zone_id=$(printf '%s\n' "$zone_info" | sed -n '1p')
hosted_zone_name=$(printf '%s\n' "$zone_info" | sed -n '2p')
created_zone=$(printf '%s\n' "$zone_info" | sed -n '3p')

printf 'Hosted zone: %s\n' "$zone_id"
printf 'Domain: %s\n' "$hosted_zone_name"
if [ "$created_zone" -eq 1 ]; then
    printf 'Created hosted zone for %s\n' "$domain"
fi
printf 'Nameservers:\n'
printf '%s\n' "$zone_info" | sed -n '4,$p' | sed 's/^/  /'

token_seed=$(printf '%s-%s-%s' "$domain" "$cert_region" "$(date -u +%s)")
idempotency_token=$(printf '%s' "$token_seed" | tr -cs 'A-Za-z0-9_' '_' | cut -c1-64)

certificate_arn=$(
    aws acm request-certificate \
        --region "$cert_region" \
        --domain-name "$domain" \
        --subject-alternative-names "*.$domain" \
        --validation-method DNS \
        --options CertificateTransparencyLoggingPreference=ENABLED,Export=ENABLED \
        --idempotency-token "$idempotency_token" \
        --query 'CertificateArn' \
        --output text
)

printf 'Requested certificate: %s\n' "$certificate_arn"
printf 'Waiting for ACM DNS validation records...\n'
validation_records_json=$(wait_for_validation_records "$cert_region" "$certificate_arn")
printf '%s\n' "$validation_records_json"
apply_validation_records "$route53_region" "$zone_id" "$validation_records_json"
printf 'Published ACM validation records in Route53\n'

printf 'Waiting for certificate issuance...\n'
wait_for_certificate_issued "$cert_region" "$certificate_arn"

passphrase_file=$(mktemp)
export_json=$(mktemp)
cleanup() {
    rm -f "$passphrase_file" "$export_json"
}
trap cleanup EXIT HUP INT TERM

openssl rand -base64 32 | tr -d '\n' > "$passphrase_file"

aws acm export-certificate \
    --region "$cert_region" \
    --certificate-arn "$certificate_arn" \
    --passphrase "fileb://$passphrase_file" \
    --output json > "$export_json"

fullchain_pem="$cert_dir/fullchain.pem"
encrypted_key_pem="$cert_dir/private-key-encrypted.pem"
private_key_pem="$cert_dir/privkey.pem"

jq -r '.Certificate' "$export_json" > "$fullchain_pem"
jq -r '.CertificateChain' "$export_json" >> "$fullchain_pem"
jq -r '.PrivateKey' "$export_json" > "$encrypted_key_pem"

openssl pkey \
    -in "$encrypted_key_pem" \
    -passin "file:$passphrase_file" \
    -out "$private_key_pem" >/dev/null 2>&1

if [ ! -s "$private_key_pem" ]; then
    printf >&2 'Failed to decrypt ACM private key for %s\n' "$domain"
    exit 1
fi

fullchain_b64=$(base64 < "$fullchain_pem" | tr -d '\n')
private_key_b64=$(base64 < "$private_key_pem" | tr -d '\n')

cat > "$env_file" <<EOF
AWS_ECS_TLS_FULLCHAIN_B64=$fullchain_b64
AWS_ECS_TLS_PRIVATE_KEY_B64=$private_key_b64
EOF

chmod 600 "$env_file"
printf 'Wrote ECS TLS env file: %s\n' "$env_file"

printf 'Deploying certificate to ECS...\n'
"$script_dir/ecs"

printf 'Updating Route53 public records...\n'
"$script_dir/route53" "$domain"

printf 'Certificate ARN: %s\n' "$certificate_arn"
