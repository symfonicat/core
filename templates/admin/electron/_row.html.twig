<tr id="electron_{{ electron.id }}" class="btn-row">
    <td class="fw-semibold">{{ electron.name }}</td>
    <td>{{ electron.type }}</td>
    <td>
        {% if electron.type == 'domain' %}
            {{ electron.domain ? electron.domain.id : '-' }}
        {% elseif electron.type == 'project' %}
            {{ electron.project ? electron.project.id ~ ' ' ~ electron.project.name : '-' }}
        {% elseif electron.type == 'application' %}
            {{ electron.application ? electron.application.id : '-' }}
        {% else %}
            -
        {% endif %}
    </td>
    <td>
        {% if electron.favicon %}
            <code>{{ electron.favicon|replace({'electron/favicon/': ''}) }}</code>
        {% else %}
            <span class="text-body-secondary">-</span>
        {% endif %}
    </td>
    <td class="text-end btn-cell">
        <div class="btn-group btn-group-sm">
            <a href="{{ path('app_electron_edit', { id: electron.id }) }}" class="btn btn-sm btn-warning">
                <i class="fa fa-pencil">&nbsp;</i>
            </a>
            {{ include('admin/electron/_delete_form.html.twig') }}
        </div>
    </td>
</tr>
