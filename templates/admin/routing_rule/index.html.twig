{% extends 'admin/base.html.twig' %}
{% block title %}Routing Rules{% endblock %}
{% block body %}

    <table class="table" id="routing-rules">
        <thead>
            <tr>
                <th>type</th>
                <th>match</th>
                <th>scope</th>
                <th>target</th>
                <th>&nbsp;</th>
            </tr>
        </thead>
        <tbody>
        {% for rule in rules %}
            {{ include('admin/routing_rule/_row.html.twig') }}
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_routing_rule_create') }}" class="btn btn-sm btn-success">create</a>

{% endblock %}
