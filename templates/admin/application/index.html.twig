{% extends 'admin/base.html.twig' %}
{% block title %}Applications{% endblock %}
{% block body %}

    <table class="table" id="applications">
        <thead>
            <tr>
                <th>id</th>
                <th>modules</th>
                <th>&nbsp;</th>
            </tr>
        </thead>
        <tbody id="applications-body">
        {% for application in applications %}
            {{ include('admin/application/_row.html.twig') }}
        {% else %}
            <tr id="applications-empty">
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_application_create') }}" class="btn btn-sm btn-success">create</a>

{% endblock %}
