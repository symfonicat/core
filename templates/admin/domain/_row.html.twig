<tr id="domain_{{ domain.id }}" class="btn-row">
    <td class="fw-semibold"><a href="{{ app.request.scheme }}://{{ domain.id }}">{{ domain.id }}</a></td>
    <td>
        {% for project in domain.projects %}
            <a href="{{ path('symfonicat_project_edit', {'id': project.id}) }}">{{ project.name }}</a>{% if not loop.last %}, {% endif %}
        {% else %}
            -
        {% endfor %}
    </td>
    {% for env_parent in env_parents %}
        <td>
            {% set entries = env_parent_entries(domain.env, env_parent) %}
            {% for entry in entries %}
                <div><code>{{ entry }}</code></div>
            {% else %}
                <span class="text-body-secondary">-</span>
            {% endfor %}
        </td>
    {% endfor %}
    <td class="text-end btn-cell">

        <div class="btn-group btn-group-sm">
            <a href="{{ path('symfonicat_domain_edit', {'id': domain.id}) }}" class="btn btn-sm btn-warning">
                <i class="fa fa-pencil">&nbsp;</i>
            </a>
            {{ include('admin/domain/_delete_form.html.twig') }}
        </div>

    </td>
</tr>
