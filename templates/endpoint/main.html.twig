{% extends 'base.html.twig' %}
{% block title %}Main Endpoint Router{% endblock %}

{% block stylesheets -%}

    {{- parent() -}}
    {% for module in endpoint.modules -%}
        {{- encore_entry_link_tags_module(module) | indent_links(8) -}}
    {%- endfor %}

    {{- encore_entry_link_tags_parcel(endpoint.parcel) | indent_links(8) -}}
    {{- encore_entry_link_tags_endpoint(endpoint) | indent_links(8) -}}

{%- endblock %}

{% block javascripts -%}

    {{- parent() -}}
    {% for module in endpoint.modules -%}
        {{- encore_entry_script_tags_module(module) | indent_scripts(8) -}}
    {%- endfor %}

    {{- encore_entry_script_tags_parcel(endpoint.parcel) | indent_scripts(8) -}}
    {{- encore_entry_script_tags_endpoint(endpoint) | indent_scripts(8) -}}

{%- endblock %}

{% block body %}

    <main id="root">
    </main>

    {{ endpoint.id }}

    <br />

    color: {{ env('colors.primary')|default('') }}
    
{% endblock %}
