<form class="d-inline" method="post" action="{{ path('app_module_delete', {'slug': module.slug}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ module.id) }}">
    <button type="submit" class="btn btn-sm btn-danger">
        <i class="fa fa-x"></i>
    </button>
</form>
