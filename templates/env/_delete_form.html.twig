<form method="post" action="{{ path('app_env_delete', {'id': env.id}) }}" onsubmit="return confirm('are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ env.id) }}">
    <button class="btn btn-sm btn-danger">
        <i class="fa fa-times">&nbsp;</i>
    </button>
</form>
